# Google account credentials (use an app-specific password if 2FA is enabled)
GOOGLE_EMAIL=your-email@gmail.com
GOOGLE_PASSWORD=your-app-password

# Claude API key for AI classification
ANTHROPIC_API_KEY=sk-ant-...

# Google Groups URL (for reference)
GROUP_URL=https://groups.google.com/g/forecast-chat

# Google Groups email address (used for IMAP search filtering)
GROUP_EMAIL=forecast-chat@googlegroups.com

# IMAP/SMTP settings (defaults work for Gmail)
IMAP_HOST=imap.gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
